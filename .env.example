# ============================================================
# NexusOps AIOps Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in actual values.
# DO NOT commit the actual .env file to git.
# ============================================================

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── MongoDB ────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
DB_NAME=metrics_db

# ── OpenAI (Analysis Service) ─────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o
LLM_TIMEOUT=30

# ── CentralServer → Analysis Service link ─────────────────────
CENTRAL_SERVER_URL=http://central-server:8000
CENTRAL_SERVER_WS_PUSH_ENDPOINT=http://central-server:8000/api/analysis-update

# ── Frontend (React build-time vars) ──────────────────────────
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000/ws
